MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_RECIPIENT_ADDRESS="hello@turancetechnologies.com"
CONTACT_RECIPIENT_NAME="Turance Technologies"
CONTACT_MINIMUM_FORM_SECONDS=2
CONTACT_MAXIMUM_FORM_AGE_SECONDS=7200
CONTACT_DEDUPLICATION_MINUTES=15
CONTACT_QUEUE_MAIL=false
CONTACT_MAIL_QUEUE=emails
CONTACT_TURNSTILE_ENABLED=false
CONTACT_TURNSTILE_SITE_KEY=
CONTACT_TURNSTILE_SECRET_KEY=
CONTACT_TURNSTILE_HOSTNAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

